# GitHub personal access token or fine-grained token.
# Required scopes depend on the repositories you manage:
# - classic PAT: repo, read:org, admin:org if org-level administration is needed
# - fine-grained PAT: repository administration/read-write for target repos
GITHUB_TOKEN=

# GitHub owner login. This can be a user or organization.
GITHUB_OWNER=
ADMIN_GITHUB_LOGINS=

# GitHub REST API version header. Keep default unless GitHub docs require another version.
GITHUB_API_VERSION=2026-03-10

# GitHub recommends a clear User-Agent for API integrations.
GITHUB_USER_AGENT=osh-github-manager

# Retry count for GitHub primary/secondary rate limit responses.
GITHUB_MAX_RETRIES=3

# Optional API token for admin endpoints. If set, send it as:
# Authorization: Bearer <ADMIN_TOKEN>
ADMIN_TOKEN=

# GitHub OAuth App. Callback URL should be:
# ${APP_BASE_URL}/auth/github/callback
APP_BASE_URL=http://localhost:4173
SESSION_SECRET=replace-with-a-long-random-string
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# SQLite database path.
DATABASE_FILE=./data/app.db

# Web server port.
PORT=4173

# Max jobs processed at once. Keep this conservative for large orgs.
JOB_CONCURRENCY=1

# Milliseconds between GitHub write operations inside a job.
JOB_DELAY_MS=500
